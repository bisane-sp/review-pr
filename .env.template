# Full Google Chat space resource name the bot is allowed to act in, e.g. "spaces/AAQA1u4..."
GOOGLE_CHAT_SPACE_ID=

# Pub/Sub subscription the bot pulls Chat events from, e.g. "projects/PROJECT/subscriptions/SUB".
PUBSUB_SUBSCRIPTION=

# Pub/Sub topic Chat events are published to, e.g. "projects/PROJECT/topics/chat-events".
# Only needed by utils/create_space_subscription.py.
CHAT_EVENTS_TOPIC=

# Path to the OAuth Desktop client JSON. Only needed by utils/create_space_subscription.py.
OAUTH_CLIENT_SECRETS=

# Google Chat incoming webhook URL used to post "merged" / failure replies back into the space.
GOOGLE_CHAT_WEBHOOK_URL=

# Path to the service-account JSON key with Pub/Sub Subscriber access (read by the Pub/Sub client).
GOOGLE_APPLICATION_CREDENTIALS=

# Two GitHub accounts. The bot approves with whichever account is NOT the PR author
# (GitHub forbids approving your own PR), then merges. ACCOUNT_n is the login/username;
# TOKEN_n is that account's Personal Access Token.
GITHUB_ACCOUNT_1=
GITHUB_TOKEN_1=

GITHUB_ACCOUNT_2=
GITHUB_TOKEN_2=

GH_TIMEOUT_SECONDS=60
